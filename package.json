{
  "name": "pi-userland",
  "version": "0.0.0",
  "description": "Personal monorepo for independently publishable Pi packages",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "pnpm -r --filter './packages/*' lint",
    "format:check": "pnpm -r --filter './packages/*' format:check",
    "format:write": "pnpm -r --filter './packages/*' format:write",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "test": "pnpm -r --filter './packages/*' test",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck"
  },
  "pi": {
    "extensions": ["./packages/*/extensions"],
    "skills": ["./packages/*/skills"],
    "prompts": ["./packages/*/prompts"],
    "themes": ["./packages/*/themes"]
  },
  "keywords": ["pi-package", "monorepo"],
  "author": "Rob Howley",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^22.15.17",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "@sinclair/typebox": "^0.34.0",
    "vitest": "^3.1.3",
    "tiktoken": "^1.0.17"
  }
}
