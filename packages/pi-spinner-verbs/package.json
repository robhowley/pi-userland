{
  "name": "@robhowley/pi-spinner-verbs",
  "version": "3.3.2",
  "type": "module",
  "description": "Themed thinking text for Pi: built-in spinner verb packs, random per-session themes, and custom verb files.",
  "license": "MIT",
  "files": [
    "extensions",
    "spinner-verbs",
    "README.md",
    "../LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-userland",
    "spinner",
    "spinner-verbs",
    "pi-extension"
  ],
  "pi": {
    "extensions": [
      "./extensions/spinner-verbs"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robhowley/pi-userland.git",
    "directory": "packages/pi-spinner-verbs"
  },
  "homepage": "https://pi-userland.dev",
  "scripts": {
    "lint": "eslint extensions/",
    "format:check": "prettier --check extensions/",
    "format:write": "prettier --write extensions/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run __tests__"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.17"
  }
}
