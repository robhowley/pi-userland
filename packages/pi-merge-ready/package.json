{
  "name": "@robhowley/pi-merge-ready",
  "version": "0.7.0",
  "description": "PR merge-readiness for Pi: status bar and slash-command status, exact PR URL targeting, blocker context, and agent repair loops.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "extensions",
    "skills",
    "README.md",
    "../LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pull-request",
    "status-bar",
    "repair-loop",
    "agent-loop",
    "github-pr",
    "code-review",
    "pi-userland"
  ],
  "pi": {
    "extensions": [
      "./extensions/merge-ready"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robhowley/pi-userland.git",
    "directory": "packages/pi-merge-ready"
  },
  "homepage": "https://pi-userland.dev",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/extensions/merge-ready/watch-ui/public && cp extensions/merge-ready/watch-ui/public/* dist/extensions/merge-ready/watch-ui/public/",
    "lint": "eslint extensions/",
    "format:check": "prettier --check extensions/",
    "format:write": "prettier --write extensions/",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run __tests__"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.17"
  }
}
