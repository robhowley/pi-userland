{
  "name": "@robhowley/pi-merge-ready",
  "version": "0.1.0",
  "description": "PR merge-readiness for Pi: status bar signal, blocker context, and agent repair loops.",
  "type": "module",
  "files": [
    "extensions",
    "README.md",
    "../LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./extensions/merge-ready"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robhowley/pi-userland.git",
    "directory": "packages/pi-merge-ready"
  },
  "homepage": "https://github.com/robhowley/pi-userland/tree/main/packages/pi-merge-ready",
  "scripts": {
    "lint": "eslint extensions/ __tests__/",
    "format:check": "prettier --check extensions/ __tests__/",
    "format:write": "prettier --write extensions/ __tests__/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run __tests__"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.17"
  }
}
