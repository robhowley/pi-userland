{
  "name": "@robhowley/pi-openrouter",
  "version": "0.5.0",
  "type": "module",
  "description": "Live OpenRouter TUI overlays for spend, credits, key limits, burn rate, model usage, and session tagging.",
  "license": "MIT",
  "files": [
    "extensions",
    "README.md",
    "../LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "openrouter"
  ],
  "pi": {
    "extensions": [
      "./extensions/openrouter"
    ],
    "image": "https://raw.githubusercontent.com/robhowley/pi-userland/main/packages/pi-openrouter/img/openrouter-usage-tui.png"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robhowley/pi-userland.git",
    "directory": "packages/pi-openrouter"
  },
  "homepage": "https://github.com/robhowley/pi-userland/tree/main/packages/pi-openrouter",
  "scripts": {
    "lint": "eslint extensions/",
    "format:check": "prettier --check extensions/",
    "format:write": "prettier --write extensions/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run __tests__"
  },
  "dependencies": {
    "@mariozechner/pi-tui": "*",
    "@openrouter/sdk": "^0.12.21"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.17"
  }
}
