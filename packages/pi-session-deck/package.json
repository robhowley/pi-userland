{
  "name": "@robhowley/pi-session-deck",
  "version": "0.7.0",
  "type": "module",
  "description": "A TUI dashboard for Pi sessions: live windows, worktrees, PRs, activity, and statuses in one place.",
  "files": [
    "extensions",
    "README.md",
    "../LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-userland",
    "sessions",
    "status"
  ],
  "pi": {
    "extensions": [
      "./extensions/session-deck"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robhowley/pi-userland.git",
    "directory": "packages/pi-session-deck"
  },
  "homepage": "https://pi-userland.dev",
  "scripts": {
    "lint": "eslint extensions/ __tests__/",
    "format:check": "prettier --check extensions/ __tests__/",
    "format:write": "prettier --write extensions/ __tests__/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run __tests__"
  },
  "license": "MIT",
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.17"
  }
}
