{
  "name": "@robhowley/pi-session-deck",
  "version": "0.11.0",
  "type": "module",
  "description": "Organize live Pi agents by repo, inspect activity and worktree context, and launch in tmux, reopen, or end them from a TUI or iTerm2 Toolbelt.",
  "files": [
    "dist",
    "extensions",
    "README.md",
    "../LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-userland",
    "pi-coding-agent",
    "coding-agent",
    "session-management",
    "agent-monitoring",
    "agent-dashboard",
    "tui",
    "iterm2",
    "iterm2-toolbelt",
    "tmux",
    "git-worktree",
    "terminal"
  ],
  "pi": {
    "extensions": [
      "./extensions/session-deck"
    ],
    "image": "https://raw.githubusercontent.com/robhowley/pi-userland/main/packages/pi-session-deck/img/session-deck-toolbelt-overview.png"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robhowley/pi-userland.git",
    "directory": "packages/pi-session-deck"
  },
  "homepage": "https://github.com/robhowley/pi-userland/tree/main/packages/pi-session-deck",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "eslint extensions/ __tests__/",
    "format:check": "prettier --check extensions/ __tests__/",
    "format:write": "prettier --write extensions/ __tests__/",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run __tests__"
  },
  "license": "MIT",
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.17"
  }
}
