{
  "name": "@robhowley/pi-structured-return",
  "version": "1.9.1",
  "description": "Turn noisy CLI output into compact structured results (fewer tokens), full logs preserved.",
  "type": "module",
  "files": [
    "extensions",
    "skills",
    "README.md",
    "../LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "pi",
    "pi-extension",
    "token-reduction",
    "structured-output"
  ],
  "pi": {
    "extensions": [
      "./extensions/structured-return"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robhowley/pi-userland.git",
    "directory": "packages/pi-structured-return"
  },
  "homepage": "https://github.com/robhowley/pi-userland/tree/main/packages/pi-structured-return",
  "scripts": {
    "lint": "eslint extensions/",
    "format:check": "prettier --check extensions/",
    "format:write": "prettier --write extensions/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run __tests__"
  },
  "dependencies": {
    "fast-xml-parser": "^5.4.1",
    "glob": "^11.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.17"
  }
}
